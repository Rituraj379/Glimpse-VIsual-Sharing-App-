{
  "name": "glimpse",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack visual sharing app with a React + Vite frontend and MERN backend.",
  "workspaces": [
    "Glimpse_frontend",
    "Glimpse_backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace Glimpse_frontend",
    "frontend:build": "npm run build --workspace Glimpse_frontend",
    "backend:dev": "npm run dev --workspace Glimpse_backend",
    "backend:start": "npm run start --workspace Glimpse_backend"
  }
}
